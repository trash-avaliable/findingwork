[gd_scene load_steps=2 format=3 uid="uid://migration_demo"]

[ext_resource type="Script" path="res://addons/enhance_save_system/demo/migration_demo.gd" id="1_md"]

[node name="MigrationDemo" type="Control"]
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_md")

[node name="VBox" type="VBoxContainer" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 20.0
offset_top = 20.0
offset_right = -20.0
offset_bottom = -20.0

[node name="Title" type="Label" parent="VBox"]
text = "存档迁移 Demo"
theme_override_font_sizes/font_size = 20

[node name="Controls" type="HBoxContainer" parent="VBox"]

[node name="CreateBtn" type="Button" parent="VBox/Controls"]
