[node name="Log" type="RichTextLabel" parent="VBox"]
size_flags_vertical = 3
bbcode_enabled = true
scroll_following = true

[connection signal="pressed" from="VBox/Controls/CreateBtn" to="." method="_on_create_old_save_pressed"]
[connection signal="pressed" from="VBox/Controls/MigrateBtn" to="." method="_on_migrate_pressed"]
[connection signal="pressed" from="VBox/Controls/CleanupBtn" to="." method="_on_cleanup_pressed"]
